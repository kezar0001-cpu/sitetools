{
    "crons": [
        {
            "path": "/api/cron-nudge",
            "schedule": "0 6 * * *"
        }
    ],
    "functions": {
        "app/api/site-docs/generate/route.ts": {
            "maxDuration": 60
        },
        "app/api/site-docs/export/[documentId]/route.ts": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/site-docs/export/:documentId",
            "destination": "/api/site-docs/export/[documentId]"
        }
    ]
}