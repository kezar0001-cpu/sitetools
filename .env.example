# Supabase project credentials
# Copy this file to .env.local and fill in your values from:
# https://supabase.com/dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
ADMIN_PASSWORD=your-admin-password

# CMS admin login (for /cms)
CMS_ADMIN_USERNAME=admin
CMS_ADMIN_PASSWORD=change-this-password
CMS_ADMIN_SESSION_TOKEN=change-this-session-token

# Buildstate Module Visibility Flags (SiteSign-First Repositioning)
NEXT_PUBLIC_SITESIGN_PRIMARY=true
NEXT_PUBLIC_SHOW_PLANNER_PRIMARY=false
NEXT_PUBLIC_SHOW_ROADMAP_MODULES=false

# Anthropic API key — server-side only, never expose to the browser
# Used by the ITP generate route (app/api/itp-generate/route.ts)
ANTHROPIC_API_KEY=your-anthropic-api-key
